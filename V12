function sw(el,id){
  document.querySelectorAll('.dtab').forEach(t=>t.classList.remove('act'));
  document.querySelectorAll('.tpanel').forEach(p=>{p.classList.remove('act');p.classList.add('hidden');});
  el.classList.add('act');
  const p=document.getElementById(id);if(p){p.classList.remove('hidden');p.classList.add('act');}
}
function setF(f,btn){
  flt=f;
  document.querySelectorAll('.fb').forEach(b=>b.classList.remove('act'));
  btn.classList.add('act');
  selId=null;
  document.getElementById('dempty').classList.remove('hidden');
  document.getElementById('dcontent').classList.add('hidden');
  renderList();
}
function onSearch(v){
  query=v.trim();selId=null;
  document.getElementById('dempty').classList.remove('hidden');
  document.getElementById('dcontent').classList.add('hidden');
  renderList();
}
function buildTimeline(){
  const all=[];
  DB.forEach(d=>(d.updates||[]).forEach(u=>all.push({date:u.d,theater:d.name,cat:d.cat,sev:d.sev,tag:u.tag,cf:u.cf,src:u.src,t:u.t})));
  const order=d=>{const m=d.match(/Jun (\d+)/);if(m)return 1000-parseInt(m[1]);if(/May|Apr|Mar|Feb|Jan|Nov|Oct|Dec/.test(d))return 2000;return 3000;};
  all.sort((a,b)=>order(a.date)-order(b.date));
  return all;
}
function openTimeline(){
  ovMode='timeline';
  document.getElementById('ovTitle').textContent='⊞ GLOBAL TIMELINE — ALL THEATERS';
  document.getElementById('tlOverlay').classList.add('show');
  const cats=['all','military','political','economic','energy','strategic'];
  document.getElementById('tlFilters').innerHTML=cats.map(c=>`<button class="fb${c===tlFilter?' act':''}" onclick="setTlFilter('${c}')">${c==='all'?'ALL':CLBL[c]}</button>`).join('');
  renderTimeline();
}
function closeOverlay(){document.getElementById('tlOverlay').classList.remove('show');}
function setTlFilter(c){tlFilter=c;openTimeline();}
function renderTimeline(){
  let items=buildTimeline();
  if(tlFilter!=='all') items=items.filter(i=>i.cat===tlFilter);
  const byDate=groupBy(items,'date');
  document.getElementById('tlScroll').innerHTML=Object.entries(byDate).map(([date,its])=>`
    <div class="tl-day"><div class="tl-date-hdr">${date}</div>
      ${its.map(i=>`<div class="tl-item${i.sev==='critical'?' crit':''}">
        <div class="tl-theater">${CCAT[i.cat]} ${i.theater}</div>
        <div class="tl-txt">${i.t}<span class="conf ${CONF[i.cf]?CONF[i.cf][1]:'cf-single'}">${CONF[i.cf]?CONF[i.cf][0]:'1-SRC'}</span>${i.src?` <span style="color:var(--txt3);font-size:7px">(${i.src})</span>`:''}</div>
      </div>`).join('')}
    </div>`).join('');
}
function openMovers(){
