  document.getElementById('ovTitle').textContent='⇅ MOVERS — BIGGEST WEEK-OVER-WEEK CHANGES (W9→W10)';
  document.getElementById('tlFilters').innerHTML='';
  document.getElementById('tlOverlay').classList.add('show');
  const scored=DB.map(d=>({d,dl:getDelta(d)}));
  const risers=scored.filter(x=>x.dl>0).sort((a,b)=>b.dl-a.dl);
  const fallers=scored.filter(x=>x.dl<0).sort((a,b)=>a.dl-b.dl);
  const flat=scored.filter(x=>x.dl===0);
  const rowHtml=({d,dl})=>{
    const col=getColor(d);
    return `<div class="mv-row" onclick="closeOverlay();sel('${d.id}')">
      <div><div class="mv-name">${CCAT[d.cat]} ${d.name}</div><div class="mv-cat">${d.region} · idx ${d.esc}</div></div>
      <div class="mv-delta" style="color:${dl>0?'var(--fire)':dl<0?'var(--sage)':'var(--txt3)'}">${deltaStr(dl)}</div>
      <div class="mv-spark">${sparkMini(d.esc_history,col)}</div>
    </div>`;
  };
  document.getElementById('tlScroll').innerHTML=`
    <div class="mv-sec" style="color:var(--fire)">↑ ESCALATING THIS WEEK (${risers.length})</div>
    ${risers.map(rowHtml).join('')||'<div style="padding:12px;font-family:var(--FM);font-size:9px;color:var(--txt3)">none</div>'}
    <div class="mv-sec" style="color:var(--sage)">↓ DE-ESCALATING THIS WEEK (${fallers.length})</div>
    ${fallers.map(rowHtml).join('')||'<div style="padding:12px;font-family:var(--FM);font-size:9px;color:var(--txt3)">none</div>'}
    <div class="mv-sec" style="color:var(--txt2)">→ UNCHANGED (${flat.length})</div>
    ${flat.map(rowHtml).join('')}`;
}
function openLeverage(){
  ovMode='leverage';
  document.getElementById('ovTitle').textContent='⚖ GLOBAL LEVERAGE MAP — WHO HOLDS WHAT LEVER';
  document.getElementById('tlFilters').innerHTML='';
  document.getElementById('tlOverlay').classList.add('show');
  const rows=[];
  DB.forEach(d=>(d.leverage||[]).forEach(l=>rows.push({theater:d.name,id:d.id,cat:d.cat,actor:l.actor,asset:l.asset,str:l.str})));
  const byStr={hi:rows.filter(r=>r.str==='hi'),md:rows.filter(r=>r.str==='md'),lo:rows.filter(r=>r.str==='lo')};
  const secLbl={hi:'⬤ HIGH LEVERAGE — actors who can change outcomes at will',md:'◐ MEDIUM LEVERAGE — meaningful but constrained',lo:'○ LOW LEVERAGE — limited or no enforcement power'};
  const secCol={hi:'var(--fire)',md:'var(--amber)',lo:'var(--sage)'};
  const rowHtml=r=>`<div class="lev-brow" onclick="closeOverlay();sel('${r.id}')">
    <div class="lev-btheater">${CCAT[r.cat]} ${r.theater}</div>
    <div class="lev-bactor">${r.actor}</div>
    <div class="lev-basset">${r.asset}</div>
    <div class="lev-str ${LEVST[r.str][1]}">${LEVST[r.str][0]}</div>
  </div>`;
  document.getElementById('tlScroll').innerHTML=`<div class="lev-board">
    <div class="lev-intro" style="margin-bottom:14px">This board aggregates every actor's primary lever across all theaters, ranked by strength. It answers a different question than the event log: not "what happened" but "who can make things happen."</div>
    ${['hi','md','lo'].map(s=>`
      <div class="lev-bcat" style="color:${secCol[s]}">${secLbl[s]} (${byStr[s].length})</div>
      ${byStr[s].map(rowHtml).join('')}
    `).join('')}
  </div>`;
}
function openExchange(){
  ovMode='exchange';
  document.getElementById('ovTitle').textContent='⇄ STRIKE-EXCHANGE BOARD — ACTIVE TIT-FOR-TAT CYCLES';
  document.getElementById('tlFilters').innerHTML='';
  document.getElementById('tlOverlay').classList.add('show');
  const chains=DB.filter(d=>d.exchange);
  document.getElementById('tlScroll').innerHTML=`<div class="exch-board">
    <div class="exch-intro" style="margin-bottom:16px">Active reciprocal strike cycles across all theaters. Each chain shows the action→reaction sequence and an escalation meter (0 = de-escalating, 100 = full war).</div>
    ${chains.map(d=>{
      const e=d.exchange;
      return `<div class="exch-bgroup">
        <div class="exch-bhdr">${CCAT[d.cat]} ${e.title}</div>
        <div class="exch-bsub">${d.name} · index ${d.esc} (Δ ${deltaStr(getDelta(d))}) · meter ${e.meter}/100 — ${e.meterLabel}</div>
        <div class="exch-meter">
          <span class="em-lbl">DE-ESCALATE</span>
          <div class="em-bar"><div class="em-needle" style="left:calc(${e.meter}% - 1px)"></div></div>
          <span class="em-lbl">FULL WAR</span>
          <span class="em-val" style="color:${e.meter>66?'var(--fire)':e.meter>40?'var(--amber)':'var(--sage)'}">${e.meter}</span>
        </div>
        <div class="exch-chain" style="cursor:pointer" onclick="closeOverlay();sel('${d.id}')">
          ${e.steps.map(s=>`
          <div class="exch-step">
            <div class="exch-date">${s.d}</div>
            <div class="exch-actor ${EACL[s.actor]||'ea-n'}">${s.al}</div>
            <div><div class="exch-act">${s.act}</div><div class="exch-resp ${ERCL[s.resp]||'er-hold'}">▸ ${s.respl}</div></div>
          </div>`).join('')}
        </div>
      </div>`;
    }).join('')}
  </div>`;
}
/* ═══ DIPLOMATIC BOARD (global) ═══ */
function openDiplomatic(){
  ovMode='diplomatic';
  document.getElementById('ovTitle').textContent='⊹ DIPLOMATIC BOARD — THE NEGOTIATION CALENDAR';
  document.getElementById('tlFilters').innerHTML='';
  document.getElementById('tlOverlay').classList.add('show');
  const rows=[];
  DB.forEach(d=>(d.diplomacy||[]).forEach(x=>rows.push({theater:d.name,id:d.id,cat:d.cat,...x})));
  const order={scheduled:0,active:1,signed:2,stalled:3,collapsed:4};
  rows.sort((a,b)=>(order[a.status]??9)-(order[b.status]??9));
  const byStatus=groupBy(rows,'status');
  const statusOrder=['scheduled','active','signed','stalled','collapsed'];
  const statusLbl={scheduled:'◷ SCHEDULED — upcoming sessions',active:'◉ ACTIVE — ongoing tracks',signed:'✓ SIGNED — agreements reached',stalled:'◌ STALLED — no movement',collapsed:'✕ COLLAPSED — rejected or dead'};
  document.getElementById('tlScroll').innerHTML=`<div class="dipl-board">
    <div class="dipl-intro" style="margin-bottom:16px">Every active negotiation across all theaters, grouped by status. This board is the counterpart to the Strike-Exchange view: it tracks the talks rather than the strikes. Week 10's lesson — the Doha Jun 30 meeting, the signed-but-rejected Lebanon framework, the Sudan HRC Jul 7 deadline — is that the negotiation calendar now drives outcomes as much as the kinetic one.</div>
    ${statusOrder.filter(s=>byStatus[s]).map(s=>`
      <div class="dipl-bgroup">
        <div class="dipl-bhdr">${statusLbl[s]} (${byStatus[s].length})</div>
        <div class="dipl-track">
          ${byStatus[s].map(x=>`
          <div class="dipl-item" style="cursor:pointer" onclick="closeOverlay();sel('${x.id}')">
            <div class="dipl-main">
              <div class="dipl-name">${x.name}</div>
              <div class="dipl-desc">${CCAT[x.cat]} ${x.theater} · ${x.desc}</div>
            </div>
            <div class="dipl-meta">
              <div class="dipl-status ${DPST[x.status][1]}">${DPST[x.status][0]}</div>
              <div class="dipl-next">${x.next.replace(/(JUL 7|JUN 30|DOHA · JUN 30)/g,'<b>$1</b>')}</div>
            </div>
          </div>`).join('')}
        </div>
      </div>`).join('')}
  </div>`;
}
/* ═══ EXPORT ═══ */
function buildKML(data){
  const cmap={critical:'ff1800e8',high:'ff0080d4',medium:'ff00c8c0',low:'ff40a814',watch:'ff2080e8',military:'ff1800e8',political:'ffb820b8',economic:'ff20a840',energy:'ff20a8e8',strategic:'ff2080d0'};
  const stys=Object.keys(cmap).map(k=>`<Style id="s-${k}"><IconStyle><color>${cmap[k]}</color><scale>1.0</scale><Icon><href>http://maps.google.com/mapfiles/kml/paddle/${k==='critical'||k==='military'?'red':k==='high'?'orange':k==='medium'?'ylw':k==='low'?'grn':k==='political'?'purple':'ltblu'}-circle.png</href></Icon></IconStyle><LabelStyle><color>${cmap[k]}</color><scale>0.7</scale></LabelStyle></Style>`).join('');
  const byCat=groupBy(data,'cat');
  const folders=Object.entries(byCat).map(([cat,items])=>`
  <Folder><name>${CLBL[cat]||cat}</name><open>1</open>
    ${items.map(d=>{const dl=getDelta(d);const lev=(d.leverage||[]).map(l=>l.actor+': '+l.asset+' ['+LEVST[l.str][0]+']').join(' | ');const exch=d.exchange?(d.exchange.title+' (meter '+d.exchange.meter+'/100): '+d.exchange.steps.map(s=>s.d+' '+s.al+' '+s.respl).join(' -> ')):'';const dipl=d.diplomacy?d.diplomacy.map(x=>x.name+' ['+DPST[x.status][0]+', next: '+x.next+']').join(' | '):'';return`
    <Placemark><name>${d.name}</name>
      <description><![CDATA[
        <b>${d.name}</b><br/><b>Category:</b> ${d.cat.toUpperCase()}<br/>
        <b>Region:</b> ${d.region}<br/><b>Domain:</b> ${d.domain}<br/>
        <b>Severity:</b> ${(d.sev||'').toUpperCase()}<br/><b>Status:</b> ${SLBL[d.status]||d.status}<br/>
        <b>Index:</b> ${d.esc}/100 (Δ W9→W10: ${deltaStr(dl)}; history: ${d.esc_history.join(' → ')})<br/>
        <b>Trend:</b> ${TLBL[d.trend]}${d.disputed?' · DISPUTED':''}${d.exchange_active?' · ACTIVE EXCHANGE':''}${d.diplomacy_active?' · ACTIVE DIPLOMACY':''}<br/><b>Note:</b> ${d.note}<br/>
        ${exch?'<b>Strike exchange:</b> '+exch+'<br/>':''}
        ${dipl?'<b>Diplomatic track:</b> '+dipl+'<br/>':''}
        <b>Leverage:</b> ${lev}<br/>
        <b>Human cost:</b> ${d.cas}<br/><br/>
        <b>Military:</b> ${(d.mil||'—').substring(0,400)}...<br/>
        <b>Political:</b> ${(d.pol||'—').substring(0,300)}...<br/>
        <b>Economic:</b> ${(d.eco||'—').substring(0,300)}...<br/>
        <i>v13.0 · 29 Jun 2026 · Week 10</i>
      ]]></description>
      <styleUrl>#s-${d.cat}</styleUrl>
      <ExtendedData>
        <Data name="Category"><value>${d.cat}</value></Data>
        <Data name="Index"><value>${d.esc}</value></Data>
        <Data name="DeltaW9W10"><value>${deltaStr(dl)}</value></Data>
        <Data name="EscHistory"><value>${d.esc_history.join('|')}</value></Data>
        <Data name="Trend"><value>${d.trend}</value></Data>
        <Data name="ActiveExchange"><value>${d.exchange_active?'YES':'no'}</value></Data>
        <Data name="ActiveDiplomacy"><value>${d.diplomacy_active?'YES':'no'}</value></Data>
        <Data name="Disputed"><value>${d.disputed?'YES':'no'}</value></Data>
      </ExtendedData>
      <Point><coordinates>${d.lon},${d.lat},0</coordinates></Point>
    </Placemark>`;}).join('')}
  </Folder>`).join('');
  return `<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2"><Document>
<name>Global Intelligence Platform v13.0 — 29 Jun 2026 (Week 10)</name>
<description>Full-spectrum: ${data.length} theaters. US-Iran spike-and-settle (Bahrain/Kuwait struck, Doha Jun 30); Lebanon framework signed; ISW resolves Ukraine map (Russia net -281 sq km); diplomatic track + strike-exchange tracker + leverage map. 5 categories, confidence-graded, W1-W10 history, auto-deltas. Sources: ISW/CTP, ACLED, Crisis Group, Yale HRL, IRC, CNN, NPR, RFERL, Al Jazeera, HRW + 20 merged user KML/KMZ files.</description>
${stys}${folders}
</Document></kml>`;
}
function dl(c,n,m){const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([c],{type:m}));a.download=n;a.click();}
function exportKML(){dl(buildKML(filteredDB()),`GIP-v13-Week10-${flt}.kml`,'application/vnd.google-earth.kml+xml');}
function exportKMZ(){dl(buildKML(filteredDB()),'GIP-v13-Week10.kmz','application/vnd.google-earth.kmz');}
function exportCSV(){
  const data=filteredDB();
  const hdr=['ID','Name','Cat','Region','Domain','Sev','Status','Trend','Index','DeltaW9W10','W1','W2','W3','W4','W5','W6','W7','W8','W9','W10','ActiveExchange','ActiveDiplomacy','Disputed','TopLeverage','Lat','Lon','HumanCost','Note'];
  const rows=data.map(d=>{const top=(d.leverage||[]).filter(l=>l.str==='hi').map(l=>l.actor).join('; ');return [d.id,`"${d.name}"`,d.cat,`"${d.region}"`,`"${d.domain}"`,d.sev||'',SLBL[d.status]||d.status,d.trend,d.esc,deltaStr(getDelta(d)),...d.esc_history,d.exchange_active?'YES':'',d.diplomacy_active?'YES':'',d.disputed?'YES':'',`"${top}"`,d.lat,d.lon,`"${d.cas}"`,`"${d.note}"`].join(',');});
  dl([hdr.join(','),...rows].join('\n'),'GIP-v13-Week10.csv','text/csv');
}
