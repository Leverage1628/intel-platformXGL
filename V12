const CONF={wire:['WIRE','cf-wire'],corr:['CORROB','cf-corr'],single:['1-SRC','cf-single'],osint:['OSINT-HOLD','cf-osint'],rumint:['RUMINT','cf-rumint'],truth:['TRUTH-SOC','cf-truth'],disputed:['⊗ DISPUTED','cf-disputed']};
const LEVST={hi:['HIGH','lev-hi'],md:['MED','lev-md'],lo:['LOW','lev-lo']};
const EACL={A:'ea-a',B:'ea-b',N:'ea-n'};
const ERCL={strike:'er-strike',deescal:'er-deescal',hold:'er-hold'};
const DPST={active:['ACTIVE','dp-active'],signed:['SIGNED','dp-signed'],stalled:['STALLED','dp-stalled'],collapsed:['COLLAPSED','dp-collapsed'],scheduled:['SCHEDULED','dp-scheduled']};
const CCAT={military:'⚔',political:'🏛',economic:'📊',energy:'🛢',strategic:'🔭'};
const CCLR={military:'var(--fire)',political:'var(--violet)',economic:'var(--sage)',energy:'var(--energy)',strategic:'var(--osint)'};
const CLBL={military:'⚔ MILITARY CONFLICTS',political:'🏛 POLITICAL EVENTS',economic:'📊 ECONOMIC INTEL',energy:'🛢 ENERGY / OIL',strategic:'🔭 STRATEGIC'};
const WEEKS=['W1','W2','W3','W4','W5','W6','W7','W8','W9','W10'];
let flt='all',selId=null,query='',ovMode='timeline',tlFilter='all';
function groupBy(a,k){return a.reduce((m,i)=>{(m[i[k]]=m[i[k]]||[]).push(i);return m},{});}
function getColor(d){return CCLR[d.cat]||SEV_C[d.sev]||'#888';}
function getDelta(d){
  const h=d.esc_history;if(!h||h.length<2)return 0;
  const nz=h.filter(v=>v>0);if(nz.length<2)return 0;
  return h[h.length-1]-h[h.length-2];
}
function deltaStr(dl){return dl>0?'+'+dl:dl<0?''+dl:'±0';}
function deltaCls(dl){if(dl>0)return 'dl-up';if(dl<0)return 'dl-dn';return 'dl-fl';}
function matchSearch(d){
  if(!query) return true;
  const q=query.toLowerCase();
  const exch=d.exchange?(d.exchange.title+' '+d.exchange.steps.map(s=>s.al+' '+s.act).join(' ')):'';
  const dipl=d.diplomacy?d.diplomacy.map(x=>x.name+' '+x.desc).join(' '):'';
  const hay=[d.name,d.sub,d.region,d.domain,d.note,d.mil,d.pol,d.eco,d.assess,exch,dipl,...(d.updates||[]).map(u=>u.t),...(d.watches||[]),...((d.leverage||[]).map(l=>l.actor+' '+l.asset))].join(' ').toLowerCase();
  return hay.includes(q);
}
function filteredDB(){
  let d=DB.filter(matchSearch);
  if(flt==='all') return d;
  if(flt==='critical') return d.filter(x=>x.sev==='critical');
  if(flt==='escalating') return d.filter(x=>x.trend==='up');
  if(flt==='deescalating') return d.filter(x=>x.trend==='dn');
  if(flt==='volatile') return d.filter(x=>x.trend==='vl');
  if(flt==='disputed') return d.filter(x=>x.disputed===true);
  if(flt==='exchange') return d.filter(x=>x.exchange_active===true);
  if(flt==='diplomatic') return d.filter(x=>x.diplomacy_active===true);
  if(flt==='w10') return d.filter(x=>x.w10===true);
  if(flt==='merged') return d.filter(x=>x.merged===true);
  return d;
}
function pipCls(d){
  if(d.cat==='political') return 'p-pol';
  if(d.cat==='economic') return 'p-eco';
  if(d.cat==='energy') return 'p-energy';
  if(d.cat==='strategic') return 'p-strategic';
  return 'p-'+d.sev.substring(0,4);
}
function sparkMini(hist,color){
  return `<div class="spark">${hist.map((v,i)=>{
    const h=Math.max(2,Math.round(v/100*16));
    const isNow=i===hist.length-1;
    return `<div class="spk-bar" style="height:${h}px;background:${isNow?color:'var(--edge3)'};${isNow?'box-shadow:0 0 3px '+color:''}"></div>`;
  }).join('')}</div>`;
}
function renderList(){
  const data=filteredDB();
  const byCat=groupBy(data,'cat');
  document.getElementById('sc').textContent=data.filter(x=>x.sev==='critical').length;
  document.getElementById('se').textContent=data.filter(x=>x.trend==='up').length;
  document.getElementById('sd').textContent=data.filter(x=>x.trend==='dn').length;
  document.getElementById('sx').textContent=data.filter(x=>x.exchange_active===true).length;
  document.getElementById('sdp').textContent=data.filter(x=>x.diplomacy_active===true).length;
  document.getElementById('st').textContent=data.length;
  const wrap=document.getElementById('listWrap');
  wrap.innerHTML='';
  if(!data.length){wrap.innerHTML='<div style="padding:20px;font-family:var(--FM);font-size:9px;color:var(--txt3);letter-spacing:1px;text-align:center">NO MATCHES'+(query?' FOR "'+query.toUpperCase()+'"':'')+'</div>';return;}
  ['military','political','economic','energy','strategic'].forEach(cat=>{
    const items=byCat[cat];
    if(!items||!items.length) return;
    items.sort((a,b)=>b.esc-a.esc);
    const byReg=groupBy(items,'region');
    const cb=document.createElement('div');
    cb.className='cat-blk';
    cb.innerHTML=`<div class="cat-hdr ch-${cat}" onclick="this.parentElement.classList.toggle('col')">
      <span>${CCAT[cat]}</span><span class="cat-lbl cl-${cat}">${CLBL[cat]}</span>
      <span class="cat-cnt">${items.length}</span><span class="cat-tog">▾</span>
    </div><div class="cat-body">`;
    Object.entries(byReg).forEach(([reg,ritems])=>{
      const rb=document.createElement('div');
      rb.className='rblk';
      rb.innerHTML=`<div class="rhdr" onclick="this.parentElement.classList.toggle('col')">
        <span class="rname">${reg.toUpperCase()}</span><span class="rcnt">${ritems.length}</span><span class="rtog">▾</span>
      </div><div class="rrows">
        ${ritems.map(d=>{
          const dl=getDelta(d);
          return `
        <div class="crow${d.id===selId?' sel':''}${d.w10?' w10':''}" onclick="sel('${d.id}')">
          <div class="pip ${pipCls(d)}"></div>
          <div>
            <div class="cn">${d.name}</div>
            <div class="cs">${d.sub}</div>
            ${d.w10?'<span class="wbadge wb10">⟡ W10</span>':''}${d.exchange_active?'<span class="wbadge wbex">⇄</span>':''}${d.diplomacy_active?'<span class="wbadge wbdp">⊹</span>':''}${d.disputed?'<span class="wbadge wbdsp">⊗</span>':''}${d.merged?'<span class="wbadge wbm">⊕</span>':''}
          </div>
          <div class="cst ${SCLS[d.status]||'ss-act'}">${SLBL[d.status]||d.status.toUpperCase()}</div>
          <div>${sparkMini(d.esc_history,getColor(d))}</div>
          <div class="idxcell">
            <span class="delta ${deltaCls(dl)}">${deltaStr(dl)}</span>
            <span style="font-family:var(--FM);font-size:11px;font-weight:700;color:${getColor(d)}">${d.esc}</span>
          </div>
        </div>`;}).join('')}
      </div>`;
      cb.querySelector('.cat-body').appendChild(rb);
    });
    cb.querySelector('.cat-body').insertAdjacentHTML('beforeend','</div>');
    wrap.appendChild(cb);
  });
}
function heroSparkline(d){
  const color=getColor(d);
  return `<div class="hero-spark">${d.esc_history.map((v,i)=>{
    const h=Math.max(3,Math.round(v/100*34));
    const isNow=i===d.esc_history.length-1;
    return `<div class="hs-col"><div class="hs-val">${v||'—'}</div>
      <div class="hs-bar" style="height:${h}px;background:${isNow?color:'var(--edge3)'};${isNow?'box-shadow:0 0 5px '+color:''}"></div>
      <div class="hs-lbl">${WEEKS[i]}</div></div>`;
  }).join('')}</div>`;
}
function conflictBlock(d){
  const disp=(d.updates||[]).filter(u=>u.cf==='disputed');
  if(!disp.length && !d.dispResolved) return '';
  let html=`<div class="disp-box"><div class="disp-hdr">⊗ CONFLICTING REPORTS — SOURCES DISAGREE</div>`;
  html+=disp.map(u=>{
    const parts=u.t.replace(/^CONFLICTING[^:]*:\s*/,'');
    return `<div class="disp-row"><div class="disp-side">${u.src}</div><div>${parts}</div></div>`;
  }).join('');
  if(d.id==='ukraine'){
    html+=`<div class="disp-res"><b>✓ RESOLVED (W10):</b> ISW's rigorous dataset settles the prior ISW-vs-DeepState dispute — Russia is net-LOSING controlled territory (−281 sq km Dec25–May26), advancing at only 7.87% of its 2025 pace, offensive "largely halted." The "first chance to win" thesis is now evidence-backed.</div>`;
  }
  html+=`</div>`;
  return html;
}
function leverageBlock(d){
