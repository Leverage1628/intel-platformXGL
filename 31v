<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MERIDIAN — Strategic Intelligence · by Leverage</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  /* Situation Room palette — slate-navy base, signal-cyan accent, disciplined severity scale */
  --void:#0a0e14; --void2:#0c1119; --panel:#111722; --panel2:#141b28; --raised:#18202f;
  --line:#1e2836; --line2:#273449; --line3:#324258;
  --ice:#e8eef5; --text:#b8c6d6; --mute:#6b7d92; --dim:#43536a; --faint:#2a3646;
  --cyan:#3dd6d0; --cyan-d:rgba(61,214,208,.10); --cyan-g:rgba(61,214,208,.35);
  --amber:#e0a030; --amber-d:rgba(224,160,48,.10);
  --red:#e2564e; --red-d:rgba(226,86,78,.11);
  --grn:#4cc98a; --grn-d:rgba(76,201,138,.10);
  --violet:#9a7ff0; --violet-d:rgba(154,127,240,.10);
  --gold:#d4b24a; --gold-d:rgba(212,178,74,.10);
  --gov:#5b9bd5; --gov-d:rgba(91,155,213,.11);
  --econ:#4cc98a; --econ-d:rgba(76,201,138,.10);
  --ext:#e07a5f; --ext-d:rgba(224,122,95,.11);
  --FD:'Barlow Condensed',sans-serif; --FB:'Inter',sans-serif; --FM:'JetBrains Mono',monospace;
  --r:6px;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%}
body{background:var(--void);color:var(--text);font-family:var(--FB);font-size:13px;line-height:1.5;display:flex;flex-direction:column;overflow:hidden;-webkit-font-smoothing:antialiased;}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;background:radial-gradient(ellipse 80% 55% at 15% -5%,rgba(61,214,208,.04),transparent 60%),radial-gradient(ellipse 70% 50% at 100% 105%,rgba(91,155,213,.035),transparent 60%);}

/* ── TOP BAR ── */
.topbar{position:relative;z-index:60;height:56px;min-height:56px;flex-shrink:0;background:rgba(12,17,25,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--line);display:flex;align-items:center;padding:0 18px;gap:14px;}
.brand{display:flex;flex-direction:column;gap:1px;}
.brand-main{font-family:var(--FD);font-size:21px;letter-spacing:4px;font-weight:700;color:var(--ice);line-height:1;}
.brand-sub b{color:var(--cyan);font-weight:700;letter-spacing:1.5px;}
.brand-sub{font-family:var(--FM);font-size:8px;letter-spacing:2.5px;color:var(--dim);}
.live-chip{display:flex;align-items:center;gap:6px;font-family:var(--FM);font-size:8px;letter-spacing:1.5px;color:var(--cyan);padding:4px 9px;border:1px solid var(--cyan-g);border-radius:100px;background:var(--cyan-d);}
.live-dot{width:5px;height:5px;border-radius:50%;background:var(--cyan);box-shadow:0 0 6px var(--cyan);animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.wk-chip{font-family:var(--FM);font-size:8px;letter-spacing:1.5px;color:var(--amber);padding:4px 9px;border:1px solid rgba(224,160,48,.3);border-radius:100px;background:var(--amber-d);}
.search{margin-left:6px;display:flex;align-items:center;gap:7px;background:var(--void2);border:1px solid var(--line2);border-radius:var(--r);padding:6px 11px;transition:border-color .2s;}
.search:focus-within{border-color:var(--cyan-g);}
.search svg{width:12px;height:12px;stroke:var(--dim);}
.search input{background:none;border:none;outline:none;color:var(--ice);font-family:var(--FM);font-size:10px;letter-spacing:.5px;width:130px;}
.search input::placeholder{color:var(--dim);}
.stats{display:flex;gap:14px;margin-left:auto;align-items:center;}
.stat{display:flex;flex-direction:column;align-items:flex-end;gap:1px;}
.stat b{font-family:var(--FM);font-size:16px;font-weight:600;line-height:1;}
.stat span{font-family:var(--FM);font-size:7px;letter-spacing:1.5px;color:var(--dim);}
.s-crit{color:var(--red)}.s-esc{color:var(--amber)}.s-desc{color:var(--grn)}.s-tot{color:var(--ice)}
.clock{font-family:var(--FM);font-size:8px;letter-spacing:1px;color:var(--dim);text-align:right;line-height:1.5;padding-left:6px;border-left:1px solid var(--line);}

/* ── TICKER / ALERT ── */
.ticker{position:relative;z-index:55;flex-shrink:0;height:30px;background:var(--void2);border-bottom:1px solid var(--line);display:flex;align-items:center;overflow:hidden;}
.ticker-tag{flex-shrink:0;height:100%;display:flex;align-items:center;gap:6px;padding:0 14px;font-family:var(--FM);font-size:8px;letter-spacing:2px;color:var(--amber);background:var(--amber-d);border-right:1px solid rgba(224,160,48,.25);}
.ticker-tag::before{content:'';width:5px;height:5px;background:var(--amber);border-radius:50%;}
.ticker-scroll{flex:1;overflow:hidden;white-space:nowrap;position:relative;}
.ticker-track{display:inline-block;padding-left:100%;animation:scroll 90s linear infinite;font-family:var(--FM);font-size:9px;letter-spacing:.5px;color:var(--mute);}
.ticker-track b{color:var(--text);font-weight:500;}
.ticker-track .up{color:var(--red);}.ticker-track .dn{color:var(--grn);}
.ticker:hover .ticker-track{animation-play-state:paused;}
@keyframes scroll{0%{transform:translateX(0)}100%{transform:translateX(-100%)}}

/* ── TOOLBAR ── */
.toolbar{position:relative;z-index:50;flex-shrink:0;background:rgba(12,17,25,.9);border-bottom:1px solid var(--line);padding:8px 18px;display:flex;align-items:center;gap:8px;overflow-x:auto;scrollbar-width:none;}
.toolbar::-webkit-scrollbar{display:none;}
.tb-label{font-family:var(--FM);font-size:8px;letter-spacing:1.5px;color:var(--dim);white-space:nowrap;flex-shrink:0;}
.btn{font-family:var(--FM);font-size:9px;letter-spacing:.5px;padding:6px 12px;border:1px solid var(--line2);border-radius:var(--r);background:var(--void2);color:var(--text);cursor:pointer;transition:all .16s;white-space:nowrap;display:flex;align-items:center;gap:5px;}
.btn:hover{border-color:var(--line3);background:var(--raised);color:var(--ice);}
.btn-gov:hover{border-color:var(--gov);color:var(--gov);}
.btn-econ:hover{border-color:var(--econ);color:var(--econ);}
.btn-ext:hover{border-color:var(--ext);color:var(--ext);}
.btn-cyan{color:var(--cyan);border-color:var(--cyan-g);}.btn-cyan:hover{background:var(--cyan-d);}
.divider{width:1px;height:18px;background:var(--line2);flex-shrink:0;margin:0 2px;}
.chip{font-family:var(--FM);font-size:8.5px;letter-spacing:.5px;padding:5px 11px;border:1px solid var(--line);border-radius:100px;background:none;color:var(--mute);cursor:pointer;transition:all .16s;white-space:nowrap;}
.chip:hover{color:var(--text);border-color:var(--line3);}
.chip.on{color:var(--void);background:var(--cyan);border-color:var(--cyan);font-weight:600;}
.chip.on[data-f=critical]{background:var(--red);border-color:var(--red);}
.chip.on[data-f=escalating]{background:var(--amber);border-color:var(--amber);}
.chip.on[data-f=deescalating]{background:var(--grn);border-color:var(--grn);}
.sub-row{position:relative;z-index:49;flex-shrink:0;background:var(--void);border-bottom:1px solid var(--line);padding:7px 18px;display:flex;align-items:center;gap:7px;overflow-x:auto;scrollbar-width:none;}
.sub-row::-webkit-scrollbar{display:none;}
.sub-chip{font-family:var(--FM);font-size:7.5px;letter-spacing:.5px;padding:4px 9px;border-radius:var(--r);background:none;color:var(--dim);cursor:pointer;transition:all .16s;white-space:nowrap;border:1px solid transparent;}
.sub-chip:hover{color:var(--text);background:var(--void2);}
.sub-chip.on{color:var(--cyan);background:var(--cyan-d);border-color:var(--cyan-g);}

/* ── LAYOUT ── */
.main{display:grid;grid-template-columns:436px 1fr;flex:1;min-height:0;position:relative;z-index:10;}
.list-pane{border-right:1px solid var(--line);display:flex;flex-direction:column;overflow:hidden;background:var(--void);}
.list-scroll{overflow-y:auto;flex:1;scrollbar-width:thin;scrollbar-color:var(--line2) transparent;}
.list-scroll::-webkit-scrollbar{width:6px}.list-scroll::-webkit-scrollbar-thumb{background:var(--line2);border-radius:3px}

/* category + subregion headers */
.cat-group{border-bottom:1px solid var(--line);}
.cat-head{padding:11px 16px 9px;display:flex;align-items:center;gap:9px;cursor:pointer;position:sticky;top:0;z-index:15;background:var(--void2);transition:background .15s;}
.cat-head:hover{background:var(--panel);}
.cat-icon{width:22px;height:22px;border-radius:var(--r);display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;}
.ci-military{background:var(--red-d);color:var(--red)}.ci-political{background:var(--violet-d);color:var(--violet)}
.ci-economic{background:var(--econ-d);color:var(--econ)}.ci-energy{background:var(--amber-d);color:var(--amber)}
.ci-strategic{background:var(--gov-d);color:var(--gov)}
.cat-name{font-family:var(--FD);font-size:13px;letter-spacing:1.5px;font-weight:600;color:var(--ice);}
.cat-count{font-family:var(--FM);font-size:9px;color:var(--dim);margin-left:auto;background:var(--void);padding:2px 8px;border-radius:100px;}
.cat-caret{font-size:9px;color:var(--dim);transition:transform .2s;}
.cat-group.closed .cat-caret{transform:rotate(-90deg)}.cat-group.closed .cat-body{display:none}
.sub-head{padding:7px 16px 6px 18px;display:flex;align-items:center;gap:8px;background:var(--void);cursor:pointer;position:sticky;top:42px;z-index:12;}
.sub-head:hover{background:var(--void2)}
.sub-mark{width:4px;height:4px;border-radius:1px;background:var(--cyan);opacity:.7;}
.sub-name{font-family:var(--FM);font-size:8px;letter-spacing:1.5px;color:var(--mute);text-transform:uppercase;}
.sub-count{font-family:var(--FM);font-size:8px;color:var(--dim);margin-left:auto;}

/* theater row */
.row{padding:11px 16px;display:grid;grid-template-columns:26px 1fr auto;gap:11px;align-items:center;cursor:pointer;border-bottom:1px solid var(--faint);transition:background .12s;position:relative;}
.row::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:transparent;transition:background .15s;}
.row:hover{background:var(--void2);}
.row:hover::before{background:var(--line3);}
.row.active{background:var(--panel);}
.row.active::before{background:var(--cyan);}
.row-flag{font-size:17px;line-height:1;text-align:center;}
.row-main{min-width:0;}
.row-name{font-family:var(--FB);font-weight:600;font-size:12.5px;color:var(--ice);line-height:1.3;letter-spacing:-.1px;}
.row-sub{font-size:10.5px;color:var(--mute);margin-top:2px;line-height:1.35;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;}
.row-tags{display:flex;gap:4px;margin-top:5px;flex-wrap:wrap;}
.tag{font-family:var(--FM);font-size:7px;letter-spacing:.5px;padding:2px 5px;border-radius:3px;line-height:1;}
.tag-gov{color:var(--gov);background:var(--gov-d)}
.tag-econ{color:var(--econ);background:var(--econ-d)}
.tag-ext{color:var(--ext);background:var(--ext-d)}
.tag-dip{color:var(--cyan);background:var(--cyan-d)}
.row-right{display:flex;flex-direction:column;align-items:flex-end;gap:4px;}
.row-idx{font-family:var(--FM);font-size:19px;font-weight:600;line-height:1;letter-spacing:-.5px;}
.row-delta{font-family:var(--FM);font-size:9px;font-weight:600;display:flex;align-items:center;gap:2px;}
.d-up{color:var(--red)}.d-dn{color:var(--grn)}.d-fl{color:var(--dim)}
.row-spark{display:flex;align-items:flex-end;gap:1.5px;height:18px;margin-top:2px;}
.sbar{width:3px;border-radius:1px;background:var(--faint);min-height:2px;}

/* ── DETAIL PANE ── */
.detail-pane{display:flex;flex-direction:column;overflow:hidden;background:var(--void2);}
.mobile-back{display:none;}
.empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;color:var(--dim);text-align:center;padding:40px;}
.empty-mark{width:64px;height:64px;border:1px solid var(--line2);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:26px;color:var(--line3);}
.empty h2{font-family:var(--FD);font-size:16px;letter-spacing:2px;color:var(--mute);font-weight:500;}
.empty p{font-family:var(--FM);font-size:9px;letter-spacing:1px;color:var(--dim);max-width:320px;line-height:1.6;}
.detail{flex:1;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--line2) transparent;}
.detail::-webkit-scrollbar{width:6px}.detail::-webkit-scrollbar-thumb{background:var(--line2);border-radius:3px}

.tabs{display:flex;background:rgba(12,17,25,.95);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);position:sticky;top:0;z-index:30;padding:0 10px;overflow-x:auto;scrollbar-width:none;}
.tabs::-webkit-scrollbar{display:none;}
.tab{font-family:var(--FM);font-size:9px;letter-spacing:1px;padding:13px 13px;color:var(--dim);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap;}
.tab:hover{color:var(--text);}
.tab.on{color:var(--ice);border-bottom-color:var(--cyan);}
.panel{display:none;}.panel.on{display:block;}

.hero{padding:22px 24px 18px;border-bottom:1px solid var(--line);}
.hero-eyebrow{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:12px;}
.pill{font-family:var(--FM);font-size:8px;letter-spacing:1px;padding:3px 8px;border-radius:100px;border:1px solid;}
.pill-cat{border-color:var(--line2);color:var(--mute);}
.pill-sev{font-weight:600;}
.sev-critical{color:var(--red);border-color:rgba(226,86,78,.4);background:var(--red-d)}
.sev-high{color:var(--amber);border-color:rgba(224,160,48,.4);background:var(--amber-d)}
.sev-medium{color:var(--gold);border-color:rgba(212,178,74,.4);background:var(--gold-d)}
.sev-watch{color:var(--gov);border-color:rgba(91,155,213,.4);background:var(--gov-d)}
.hero-title{font-family:var(--FD);font-size:27px;letter-spacing:.5px;font-weight:700;color:var(--ice);line-height:1.08;margin-bottom:6px;display:flex;align-items:center;gap:11px;}
.hero-flag{font-size:26px;}
.hero-sub{font-size:12px;color:var(--mute);line-height:1.4;}
.hero-meta{display:flex;gap:16px;margin-top:14px;flex-wrap:wrap;}
.hm{display:flex;flex-direction:column;gap:2px;}
.hm-label{font-family:var(--FM);font-size:7px;letter-spacing:1.5px;color:var(--dim);}
.hm-val{font-family:var(--FM);font-size:11px;color:var(--text);font-weight:500;}

/* index gauge */
.gauge{display:flex;align-items:center;gap:16px;margin-top:16px;padding:14px 16px;background:var(--void);border:1px solid var(--line);border-radius:8px;}
.gauge-num{font-family:var(--FM);font-size:38px;font-weight:600;line-height:.9;letter-spacing:-1px;}
.gauge-info{flex:1;}
.gauge-bar{height:5px;background:var(--faint);border-radius:100px;overflow:hidden;margin-bottom:7px;}
.gauge-fill{height:100%;border-radius:100px;}
.gauge-scale{display:flex;justify-content:space-between;font-family:var(--FM);font-size:7px;color:var(--dim);letter-spacing:.5px;}
.gauge-trend{font-family:var(--FM);font-size:9px;padding:4px 9px;border-radius:var(--r);white-space:nowrap;}
.trend-up{color:var(--red);background:var(--red-d)}.trend-dn{color:var(--grn);background:var(--grn-d)}
.trend-ss{color:var(--gold);background:var(--gold-d)}.trend-vl{color:var(--amber);background:var(--amber-d)}

/* history sparkline big */
.hist{padding:16px 24px;border-bottom:1px solid var(--line);}
.hist-head{font-family:var(--FM);font-size:8px;letter-spacing:1.5px;color:var(--dim);margin-bottom:12px;}
.hist-bars{display:flex;align-items:flex-end;gap:5px;height:56px;}
.hist-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:5px;}
.hist-v{font-family:var(--FM);font-size:7px;color:var(--mute);}
.hist-b{width:100%;max-width:20px;border-radius:2px 2px 0 0;min-height:3px;transition:height .3s;}
.hist-w{font-family:var(--FM);font-size:6.5px;color:var(--dim);letter-spacing:.3px;}

/* intel columns */
.intel{display:grid;grid-template-columns:1fr;gap:0;}
.icol{padding:16px 24px;border-bottom:1px solid var(--line);}
.icol-head{font-family:var(--FM);font-size:8px;letter-spacing:1.5px;margin-bottom:10px;display:flex;align-items:center;gap:7px;}
.icol-head::before{content:'';width:6px;height:6px;border-radius:50%;background:currentColor;}
.ih-mil{color:var(--red)}.ih-pol{color:var(--violet)}.ih-eco{color:var(--econ)}
.icol-body{font-size:13px;line-height:1.68;color:var(--text);}
.icol-body p{margin-bottom:9px}.icol-body p:last-child{margin-bottom:0}

.section{padding:16px 24px;border-bottom:1px solid var(--line);}
.section-head{font-family:var(--FM);font-size:8px;letter-spacing:1.5px;color:var(--dim);margin-bottom:12px;}
.assess-box{background:var(--void);border:1px solid var(--line);border-left:2px solid var(--cyan);border-radius:0 8px 8px 0;padding:15px 17px;font-size:13px;line-height:1.72;color:var(--text);}

/* data cards (gov/lev/econ/ext) */
.cards{display:flex;flex-direction:column;gap:7px;}
.card{background:var(--void);border:1px solid var(--line);border-radius:8px;padding:12px 14px;transition:border-color .15s;}
.card:hover{border-color:var(--line2);}
.card-gov{border-left:2px solid var(--gov)}
.card-lev{border-left:2px solid var(--amber)}
.card-econ{border-left:2px solid var(--econ)}
.card-ext{border-left:2px solid var(--ext)}
.card-top{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:6px;}
.card-actor{font-family:var(--FM);font-size:10px;color:var(--ice);font-weight:500;letter-spacing:.2px;}
.card-actor .sub{font-family:var(--FM);font-size:7px;color:var(--dim);letter-spacing:.5px;text-transform:uppercase;margin-top:2px;}
.card-body{font-size:12px;line-height:1.5;color:var(--text);}
.card-extract{font-size:11px;line-height:1.45;color:var(--mute);margin-top:5px;}
.pt-thesis{font-size:12px;line-height:1.5;color:var(--fg);opacity:.9;margin:2px 0 10px;padding:9px 11px;background:var(--card2,rgba(255,255,255,.03));border-radius:8px;font-style:italic;}
.pl-wrap{padding:4px 0 2px;}
.pl-stage{border-left:2px solid var(--line);padding:2px 0 2px 12px;margin:0 0 2px 6px;}
.pl-stg-lbl{font-size:10px;font-weight:700;letter-spacing:.5px;margin-bottom:5px;text-transform:uppercase;}
.pl-node{background:var(--card2,rgba(255,255,255,.02));border:1px solid var(--line);border-radius:7px;padding:7px 9px;margin-bottom:5px;position:relative;}
.pl-actor{font-size:12.5px;font-weight:650;color:var(--fg);margin-bottom:2px;}
.pl-detail{font-size:11px;line-height:1.45;color:var(--mute);}
.pl-who{font-size:10.5px;color:var(--red);margin-top:4px;font-weight:600;}
.pl-node .badge{margin-top:5px;}
.pl-arrow{font-size:14px;color:var(--mute);text-align:left;margin:0 0 2px 12px;line-height:1;opacity:.55;}
.hist-roots{font-size:13px;line-height:1.7;color:var(--text);}
.htl{position:relative;margin-top:4px;}
.htl-row{display:grid;grid-template-columns:92px 16px 1fr;gap:0;align-items:start;}
.htl-date{font-family:var(--FM);font-size:11px;color:var(--amber);font-weight:600;padding:6px 8px 6px 0;text-align:right;white-space:nowrap;}
.htl-line{position:relative;display:flex;justify-content:center;}
.htl-line:before{content:'';position:absolute;top:0;bottom:-6px;width:1px;background:var(--line2);left:50%;transform:translateX(-50%);}
.htl-row:last-child .htl-line:before{bottom:auto;height:14px;}
.htl-dot{width:7px;height:7px;border-radius:50%;background:var(--amber);margin-top:9px;position:relative;z-index:1;box-shadow:0 0 0 3px var(--void2);}
.htl-e{font-size:12px;line-height:1.5;color:var(--text);padding:6px 0 12px 10px;}
.hact{display:flex;flex-direction:column;gap:9px;margin-top:4px;}
.hact-card{background:var(--void2);border:1px solid var(--line);border-left:3px solid var(--ext);border-radius:8px;padding:10px 12px;}
.hact-name{font-size:12.5px;font-weight:700;color:var(--fg);margin-bottom:3px;}
.hact-bio{font-size:11.5px;line-height:1.55;color:var(--mute);}
.hist-bridge{font-size:12.5px;line-height:1.65;color:var(--text);border-left:3px solid var(--red);padding:8px 12px;background:var(--void2);border-radius:0 8px 8px 0;}
.hsrc{display:flex;flex-direction:column;gap:7px;}
