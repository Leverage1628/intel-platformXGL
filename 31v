function openContested(){
  const withC=DB.filter(d=>d.contested&&d.contested.claims&&d.contested.claims.length).sort((a,b)=>b.esc-a.esc);
  const none=DB.filter(d=>d.contested&&(!d.contested.claims||!d.contested.claims.length));
  // tally statuses
  const tally={};
  withC.forEach(d=>d.contested.claims.forEach(c=>{const k=c.status.split('\u2014')[0].trim();tally[k]=(tally[k]||0)+1;}));
  const nClaims=Object.values(tally).reduce((a,b)=>a+b,0);
  const chips=Object.entries(tally).sort((a,b)=>b[1]-a[1]).map(([k,v])=>
    `<span class="ct-st ${stCls(k)}" style="margin:0 5px 5px 0">${k} \u00b7 ${v}</span>`).join('');
  const cards=withC.map(d=>`
    <div class="ctb-card" onclick="closeOverlay();pick('${d.id}')">
      <div class="ctb-head">
        <div class="ctb-n">${d.flag||''} ${d.name}</div>
        <div class="ctb-e ${d.esc>=90?'e-crit':(d.esc>=75?'e-sev':'e-elev')}">${d.esc}</div>
      </div>
      <div class="ctb-sum">${d.contested.summary}</div>
      ${d.contested.claims.map(c=>`<div class="ctb-cl">
        <span class="ct-st ${stCls(c.status)}">${c.status.split('\u2014')[0].trim()}</span>
        <div class="ctb-ct">${c.claim}</div>
      </div>`).join('')}
    </div>`).join('');
  board('\u25c9 CONTESTED \u00b7 THE NARRATIVE WAR',
    `<div class="intro-note">Where the story and the ground don't match. Every claim is scored on what the evidence actually supports \u2014 not on who said it. <b>${withC.length} of ${DB.length} theaters</b> carry an active narrative war (${nClaims} contested claims). The other ${none.length} are marked as having none: <b>the absence of an information operation is itself a finding</b>, so it is stated rather than left blank.</div>
     <div class="ctb-tally">${chips}</div>
     ${cards}
     <div class="ctb-clean"><div class="ctb-ch">\u2713 NO SIGNIFICANT NARRATIVE WAR (${none.length})</div>
       <div class="ctb-cl2">${none.map(d=>`<span class="grp-th" onclick="closeOverlay();pick('${d.id}')">${d.flag||''} ${d.name.split('\u2014')[0].trim()}</span>`).join('')}</div></div>`);
}
function openMovers(){
  const real=DB.filter(d=>d.hist_real!==false);
  const seeded=DB.filter(d=>d.hist_real===false);
  const wd=d=>{const h=d.esc_history;return h[h.length-1]-h[h.length-2];};
  const up=real.filter(d=>wd(d)>0).sort((a,b)=>wd(b)-wd(a));
  const dn=real.filter(d=>wd(d)<0).sort((a,b)=>wd(a)-wd(b));
  const fl=real.filter(d=>wd(d)===0).sort((a,b)=>b.esc-a.esc);
  const row=d=>{const x=wd(d);const s=x>0?'+'+x:(x<0?''+x:'0');
    return `<div class="mv-row" onclick="closeOverlay();pick('${d.id}')">
      <div class="mv-d ${x>0?'mv-up':(x<0?'mv-dn':'mv-fl')}">${s}</div>
      <div class="mv-n">${d.flag||''} ${d.name}</div>
      <div class="mv-e">${d.esc}</div></div>`;};
  const srow=d=>`<div class="mv-row mv-seed" onclick="closeOverlay();pick('${d.id}')">
      <div class="mv-d mv-est">EST</div>
      <div class="mv-n">${d.flag||''} ${d.name}</div>
      <div class="mv-e">${d.esc}</div></div>`;
  board('\u21c5 MOVERS \u00b7 WEEK-OVER-WEEK',
    `<div class="intro-note">Ranked by change since last week. <b>Only theaters with real tracked history appear in the movement columns</b> \u2014 newly-seeded theaters have estimated back-history and cannot show meaningful deltas, so they are listed separately below rather than polluting the signal.</div>
     <div class="mv-sec"><div class="mv-h mv-hu">\u25b2 ESCALATING (${up.length})</div>${up.map(row).join('')||'<div class="mv-empty">None this week.</div>'}</div>
     <div class="mv-sec"><div class="mv-h mv-hd">\u25bc EASING (${dn.length})</div>${dn.map(row).join('')||'<div class="mv-empty">None this week.</div>'}</div>
     <div class="mv-sec"><div class="mv-h mv-hf">\u2014 HOLDING (${fl.length})</div>${fl.map(row).join('')}</div>
     <div class="mv-sec"><div class="mv-h mv-hs">\u25c8 NOT YET TRACKABLE (${seeded.length}) \u00b7 estimated back-history</div>
       <div class="mv-note">These theaters entered tracking recently. Their 10-week curves are analyst estimates, not observed movement \u2014 so no delta is claimed until two real weeks accumulate.</div>
       ${seeded.map(srow).join('')}</div>`);
}
function buildKML(data){
  const cm={military:'ff4e56e2',political:'fff07f9a',economic:'ff8ac94c',energy:'ff30a0e0',strategic:'ffd59b5b'};
  const ic={military:'red',political:'purple',economic:'grn',energy:'wht',strategic:'ltblu'};
  const st=Object.keys(cm).map(k=>`<Style id="s-${k}"><IconStyle><color>${cm[k]}</color><scale>1.1</scale><Icon><href>http://maps.google.com/mapfiles/kml/paddle/${ic[k]}-circle.png</href></Icon></IconStyle><LabelStyle><scale>.7</scale></LabelStyle></Style>`).join('');
  const bs=grp(data,'subregion');
  const folders=SUBS.filter(s=>bs[s]).map(sub=>`<Folder><name>${sub}</name>${bs[sub].filter(d=>!d.offmap&&d.lat!=null&&d.lon!=null).map(d=>{
    const dl=dlt(d);const ext=(d.external||[]).map(x=>`${x.actor}→${x.side} [${TIER[x.tier]}]: ${x.flow}`).join(' | ');
    return `<Placemark><name>${d.flag||''} ${d.name}${d.external?' ◆':''}</name><description><![CDATA[<b>${d.name}</b><br/>Index: ${d.esc}/100 (Δ${dstr(dl)})<br/>Status: ${SLBL[d.status]||d.status}<br/>${d.note}<br/>${ext?'<b>External:</b> '+ext:''}<br/><i>v56 · Week 16</i>]]></description><styleUrl>#s-${d.cat}</styleUrl><Point><coordinates>${d.lon},${d.lat},0</coordinates></Point></Placemark>`;
  }).join('')}</Folder>`).join('');
  return `<?xml version="1.0" encoding="UTF-8"?><kml xmlns="http://www.opengis.net/kml/2.2"><Document><name>MERIDIAN by Leverage — Week 16</name>${st}${folders}</Document></kml>`;
}
function dl(c,n,m){const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([c],{type:m}));a.download=n;a.click();}
function exportKML(){dl(buildKML(fdb()),'MERIDIAN-Leverage-W16.kml','application/vnd.google-earth.kml+xml');}
function exportCSV(){
  const data=fdb();const h=['Name','Category','Subregion','Domain','Severity','Status','Index','Delta','Lat','Lon'];
  const rows=data.map(d=>[`"${d.name}"`,d.cat,`"${d.subregion}"`,`"${d.domain}"`,d.sev,SLBL[d.status]||d.status,d.esc,dstr(dlt(d)),d.lat,d.lon].join(','));
  dl([h.join(','),...rows].join('\n'),'MERIDIAN-Leverage-W16.csv','text/csv');
}
