function color(d){return CCLR[d.cat]||SEV[d.sev]||'#888';}
function grp(a,k){return a.reduce((m,i)=>((m[i[k]]=m[i[k]]||[]).push(i),m),{});}
function dlt(d){const h=d.esc_history,nz=h.filter(v=>v>0);if(nz.length<2)return 0;return h[h.length-1]-h[h.length-2];}
function dstr(x){return x>0?'+'+x:x<0?''+x:'0';}
function dcls(x){return x>0?'d-up':x<0?'d-dn':'d-fl';}

function matchWhere(d){
  // returns array of match locations, or [] if no match
  if(!q) return ['all'];
  const s=q.toLowerCase(); const hits=[];
  if([d.name,d.sub,d.region,d.subregion,d.domain,d.note,d.mil,d.pol,d.eco,d.assess].join(' ').toLowerCase().includes(s)) hits.push('theater');
  if((d.gov||[]).some(g=>(g.src+' '+g.detail).toLowerCase().includes(s))) hits.push('gov');
  if((d.leverage||[]).some(l=>(l.actor+' '+l.asset).toLowerCase().includes(s))) hits.push('leverage');
  if((d.econlev||[]).some(e=>(e.holder+' '+e.channel+' '+e.detail).toLowerCase().includes(s))) hits.push('econ');
  if((d.external||[]).some(x=>(x.actor+' '+x.side+' '+x.flow+' '+x.for).toLowerCase().includes(s))) hits.push('external');
  // systems: does this theater appear as a node in a matching system, or does a system match by name?
  (typeof SYSTEMS!=='undefined'?SYSTEMS:[]).forEach(sys=>{
    const sysText=(sys.name+' '+sys.type+' '+sys.summary+' '+sys.significance).toLowerCase();
    const nodeHit=(sys.nodes||[]).some(n=>n.theater===d.id && sysText.includes(s));
    const nameHit=(sys.nodes||[]).some(n=>n.theater===d.id) && sysText.includes(s);
    if(nodeHit||nameHit) hits.push('system');
  });
  (typeof INVEST!=='undefined'?INVEST:[]).forEach(inv=>{
    const invText=(inv.commodity+' '+inv.use+' '+inv.chokehold+' '+inv.signal+' '+inv.vectors).toLowerCase();
    if((inv.theaters||[]).includes(d.id) && invText.includes(s)) hits.push('investment');
  });
  (typeof GROUPS!=='undefined'?GROUPS:[]).forEach(g=>{
    const gText=(g.name+' '+g.full+' '+g.affil+' '+g.military+' '+g.logistics+' '+g.economy+' '+g.note).toLowerCase();
    if((g.theaters||[]).includes(d.id) && gText.includes(s)) hits.push('group');
  });
  (typeof BLOCS!=='undefined'?BLOCS:[]).forEach(b=>{
    const bText=(b.name+' '+b.arena+' '+b.members+' '+b.contest+' '+b.fault).toLowerCase();
    if((b.theaters||[]).includes(d.id) && bText.includes(s)) hits.push('bloc');
  });
  return hits;
}
function matches(d){ return matchWhere(d).length>0; }
function fdb(){
  let d=DB.filter(matches);
  if(subFlt!=='all')d=d.filter(x=>x.subregion===subFlt);
  if(flt==='critical')return d.filter(x=>x.sev==='critical');
  if(flt==='escalating')return d.filter(x=>x.trend==='up');
  if(flt==='deescalating')return d.filter(x=>x.trend==='dn');
  if(flt==='africa')return d.filter(x=>AFRICA.includes(x.subregion));
  if(flt==='latam')return d.filter(x=>['South America','Caribbean','North America'].includes(x.subregion)&&x.id!=='us-politics');
  if(flt==='conflict')return d.filter(x=>x.tclass==='conflict');
  if(flt==='watch')return d.filter(x=>x.tclass==='watch');
  return d;
}
function spark(h,c){return `<div class="row-spark">${h.map((v,i)=>{const ht=Math.max(2,Math.round(v/100*18));const now=i===h.length-1;return `<div class="sbar" style="height:${ht}px;${now?'background:'+c:''}"></div>`;}).join('')}</div>`;}

function renderSubFilter(){
  const present=[...new Set(DB.map(d=>d.subregion))];
  document.getElementById('subFilter').innerHTML=SUBS.filter(s=>present.includes(s)).map(s=>
    `<button class="sub-chip${subFlt===s?' on':''}" onclick="setSub('${s.replace(/'/g,"\\'")}')">${s}</button>`).join('');
}
function setSub(s){subFlt=(subFlt===s?'all':s);clearSel();renderSubFilter();renderList();}

function renderTicker(){
  const items=[...DB].sort((a,b)=>b.esc-a.esc).map(d=>{
    const dl=dlt(d);const arrow=dl>0?`<span class="up">▲${dl}</span>`:dl<0?`<span class="dn">▼${Math.abs(dl)}</span>`:'';
    return `${d.flag} <b>${d.name.split('—')[0].trim()}</b> ${d.esc} ${arrow}`;
  }).join('  ·  ');
  document.getElementById('ticker').innerHTML=items+'  ·  ';
}

function renderList(){
  const data=fdb();
  document.getElementById('sc').textContent=data.filter(x=>x.sev==='critical').length;
  document.getElementById('se').textContent=data.filter(x=>x.trend==='up').length;
  document.getElementById('sd').textContent=data.filter(x=>x.trend==='dn').length;
  document.getElementById('st').textContent=data.length;
  const wrap=document.getElementById('listWrap');
  if(!data.length){wrap.innerHTML='<div style="padding:30px;text-align:center;font-family:var(--FM);font-size:10px;color:var(--dim);letter-spacing:1px">NO MATCHES</div>';return;}
  const byCat=grp(data,'cat');
  wrap.innerHTML=CORDER.filter(c=>byCat[c]).map(cat=>{
    const items=byCat[cat].sort((a,b)=>b.esc-a.esc);
    const bySub=grp(items,'subregion');
    const subHtml=SUBS.filter(s=>bySub[s]).map(sub=>{
      const rows=bySub[sub].map(d=>{
        const dl=dlt(d),c=color(d);
        const tags=[];
        tags.push(d.tclass==='conflict'?'<span class="tag tag-conflict">⚔ CONFLICT</span>':'<span class="tag tag-watch">◎ WATCH</span>');
        if(q){const w=matchWhere(d).filter(x=>x!=='theater'&&x!=='all');if(w.length)tags.push('<span class="match-tag">↳ '+w.join(' · ')+'</span>');}
        if(d.gov&&d.gov.length)tags.push('<span class="tag tag-gov">GOV</span>');
        if(d.econlev&&d.econlev.length)tags.push('<span class="tag tag-econ">ECON</span>');
        if(d.external&&d.external.length)tags.push('<span class="tag tag-ext">EXT</span>');
        if(d.diplomacy_active)tags.push('<span class="tag tag-dip">DIPL</span>');
        return `<div class="row${d.id===sel?' active':''}" onclick="pick('${d.id}')">
          <div class="row-flag">${d.flag||'●'}</div>
          <div class="row-main">
            <div class="row-name">${d.name}</div>
            <div class="row-sub">${d.sub}</div>
            ${tags.length?`<div class="row-tags">${tags.join('')}</div>`:''}
          </div>
          <div class="row-right">
            <div class="row-idx" style="color:${c}">${d.esc}</div>
            <div class="row-delta ${dcls(dl)}">${dl>0?'▲':dl<0?'▼':'►'} ${dstr(dl)}</div>
            ${spark(d.esc_history,c)}
          </div>
        </div>`;
      }).join('');
      return `<div class="sub-head" onclick="event.stopPropagation()"><span class="sub-mark"></span><span class="sub-name">${sub}</span><span class="sub-count">${bySub[sub].length}</span></div>${rows}`;
    }).join('');
    return `<div class="cat-group">
      <div class="cat-head" onclick="this.parentElement.classList.toggle('closed')">
        <div class="cat-icon ci-${cat}">${CICON[cat]}</div>
        <div class="cat-name">${CNAME[cat]}</div>
        <div class="cat-count">${items.length}</div>
        <div class="cat-caret">▾</div>
      </div>
      <div class="cat-body">${subHtml}</div>
    </div>`;
  }).join('');
}

function bigHist(d){
  const c=color(d);
  const bars=`<div class="hist-bars">${d.esc_history.map((v,i)=>{
    const h=Math.max(3,Math.round(v/100*42));const now=i===d.esc_history.length-1;
    return `<div class="hist-col"><div class="hist-v">${v||'·'}</div><div class="hist-b" style="height:${h}px;background:${now?c:'var(--faint)'}"></div><div class="hist-w">${WEEKS[i]}</div></div>`;
  }).join('')}</div>`;
  const note=d.hist_real
    ? `<div class="hist-note real">Tracked week-over-week since ${d.tracked_since||'2026'}.</div>`
    : `<div class="hist-note">⚠ Trend estimate — this theater entered tracking ${d.tracked_since||'recently'}. Only the current value is independently verified; earlier bars are an analytic estimate of trajectory, not a recorded series.</div>`;
  return bars+note;
}
