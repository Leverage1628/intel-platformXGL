      <div class="snap-cell"><b style="color:var(--red)">${conflict}</b><span>⚔ CONFLICT</span></div>
      <div class="snap-cell"><b style="color:var(--gov)">${watch}</b><span>◎ WATCH</span></div>
      <div class="snap-cell"><b style="color:var(--amber)">${nGroups}</b><span>🏴 GROUPS</span></div>
    </div>
