function openPipeline(){
  const w=DB.filter(d=>d.pipeline&&d.pipeline.length);
  const STG={mine:['① MINE / EXTRACTION','var(--red)'],process:['② PROCESS / REFINE','var(--amber)'],mid:['③ COMPONENT / MIDSTREAM','var(--cyan)'],end:['④ END-BUYER / PRODUCT','var(--grn)']};
  const chain=(p)=>{
    const bySt={mine:[],process:[],mid:[],end:[]};
    p.forEach(s=>{(bySt[s.stage]=bySt[s.stage]||[]).push(s);});
    return ['mine','process','mid','end'].filter(k=>bySt[k]&&bySt[k].length).map((k,i,arr)=>{
      const rows=bySt[k].map(s=>`<div class="pl-node"><div class="pl-actor">${s.actor}</div><div class="pl-detail">${s.detail}</div>${s.who?`<div class="pl-who">⚑ ${s.who}</div>`:''}${s.tier?`<span class="badge b-${s.tier}">${TIER[s.tier]||s.tier}</span>`:''}</div>`).join('');
      const arrow=i<arr.length-1?`<div class="pl-arrow">↓</div>`:'';
      return `<div class="pl-stage"><div class="pl-stg-lbl" style="color:${STG[k][1]}">${STG[k][0]}</div>${rows}</div>${arrow}`;
    }).join('');
  };
  board('⛓ RESOURCE-PIPELINE BOARD','',
    `<div class="intro-note" style="margin-bottom:14px">The full extraction chain per theater — <b>who digs it → who processes it → who builds with it → who profits</b>. This is the leverage-and-extraction lens made literal: the money and the material tracked from the pit to the product on the shelf. Conflict-financing nodes are flagged ⚑.</div>`+
    w.map(d=>{
      const mineral=d.pipeline[0]&&d.pipeline[0].mineral?`<span class="ov-gmeta">${[...new Set(d.pipeline.map(p=>p.mineral).filter(Boolean))].join(' · ')}</span>`:`<span class="ov-gmeta">${d.subregion} · IDX ${d.esc}</span>`;
      return `<div class="ov-group"><div class="ov-ghead" onclick="closeOverlay();pick('${d.id}')" style="cursor:pointer"><span class="ov-gflag">${d.flag}</span>${d.name.split('—')[0].trim()}${mineral}</div><div class="pl-wrap">${chain(d.pipeline)}</div></div>`;
    }).join(''));
}
