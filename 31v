function swtab(el,id){
  el.parentElement.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));
  el.classList.add('on');document.getElementById('p-'+id).classList.add('on');
}

function renderSnapshot(){
  const el=document.getElementById('snapshot'); if(!el)return;
  const TC={CRITICAL:'var(--red)',SEVERE:'var(--amber)',ELEVATED:'var(--gold)',GUARDED:'var(--gov)',STABLE:'var(--grn)'};
  const order=['CRITICAL','SEVERE','ELEVATED','GUARDED','STABLE'];
  const counts={}; DB.forEach(d=>counts[d.tier]=(counts[d.tier]||0)+1);
  const total=DB.length;
  const segs=order.filter(t=>counts[t]).map(t=>`<div class="tierseg" style="flex:${counts[t]};background:${TC[t]}" title="${t}: ${counts[t]}">${counts[t]}</div>`).join('');
  const legend=order.filter(t=>counts[t]).map(t=>`<span class="tl"><i style="background:${TC[t]}"></i>${t}</span>`).join('');
  const movers=DB.map(d=>({d,dl:dlt(d)})).filter(x=>x.dl!==0).sort((a,b)=>Math.abs(b.dl)-Math.abs(a.dl)).slice(0,4);
  const mv=movers.length? movers.map(({d,dl})=>`<div class="snap-mv" onclick="pick('${d.id}')">
      <span class="snap-mv-d" style="color:${dl>0?'var(--red)':'var(--grn)'}">${dl>0?'▲':'▼'}${Math.abs(dl)}</span>
      <span class="snap-mv-n">${d.flag} ${d.name.split('—')[0].trim()}</span>
      <span class="snap-mv-i" style="color:${color(d)}">${d.esc}</span></div>`).join('')
    : `<div style="font-family:var(--FM);font-size:9px;color:var(--dim);padding:8px">No index changes this week.</div>`;
  const conflict=DB.filter(d=>d.tclass==='conflict').length;
  const watch=DB.filter(d=>d.tclass==='watch').length;
  const nGroups=(typeof GROUPS!=='undefined')?GROUPS.length:0;
  el.innerHTML=`
    <div>
      <div class="snap-title">GLOBAL POSTURE · ${total} THEATERS</div>
      <div class="tierbar" style="margin-top:8px">${segs}</div>
      <div class="tierlegend" style="margin-top:9px">${legend}</div>
    </div>
