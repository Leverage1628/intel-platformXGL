      <div class="snap-title">BIGGEST MOVERS THIS WEEK</div>
      <div class="snap-movers" style="margin-top:8px">${mv}</div>
    </div>
    <div style="font-family:var(--FM);font-size:8px;color:var(--dim);letter-spacing:.5px;line-height:1.6;text-align:left;padding-top:4px;border-top:1px solid var(--faint)">
      Tap any theater for its dossier. Use the boards above to see the actors (Groups, Patrons), the structure (Blocs, Systems), and the leverage (Military, Economic, Markets).
    </div>`;
}
