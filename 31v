function stCls(s){
  if(s.startsWith('DISPROVEN'))return 'st-dis';
  if(s.startsWith('DOCUMENTED'))return 'st-doc';
  if(s.startsWith('UNRESOLVED'))return 'st-unr';
  if(s.startsWith('CONTESTED'))return 'st-con';
  if(s.startsWith('UNSUPPORTED'))return 'st-uns';
  if(s.startsWith('ALLEGED'))return 'st-unr';
  return 'st-con';
}
function contestedPanel(d){
  const c=d.contested;
  if(!c) return '<div class="ct-none">No contested-claims data for this theater.</div>';
  if(!c.claims||!c.claims.length) return `<div class="ct-none">${c.summary}</div>`;
  return `<div class="ct-lead">${c.summary}</div>`+c.claims.map(x=>`
    <div class="ct-card">
      <div class="ct-claim"><div class="ct-ck">THE CLAIM</div><div class="ct-cv">${x.claim}</div></div>
      <div class="ct-body">
        <div class="ct-sec ct-who"><div class="ct-k">WHO BENEFITS IF IT'S BELIEVED</div><div class="ct-v">${x.who}</div></div>
        <div class="ct-sec ct-ev"><div class="ct-k">WHAT THE EVIDENCE SUPPORTS</div><div class="ct-v">${x.evid}</div></div>
        <span class="ct-st ${stCls(x.status)}">\u25c9 ${x.status}</span>
      </div>
    </div>`).join('');
}
function xlinks(d){
  const gs=(typeof GROUPS!=='undefined'?GROUPS:[]).filter(g=>(g.theaters||[]).includes(d.id));
  const bs=(typeof BLOCS!=='undefined'?BLOCS:[]).filter(b=>(b.theaters||[]).includes(d.id));
  const ss=(typeof SYSTEMS!=='undefined'?SYSTEMS:[]).filter(s=>(s.nodes||[]).some(n=>n.theater===d.id));
  if(!gs.length&&!bs.length&&!ss.length) return '';
  let h='<div class="xl-wrap">';
  if(gs.length){h+=`<div class="xl-k">ARMED GROUPS ACTIVE HERE</div><div class="xl-chips">${gs.map(g=>`<span class="xl-chip xl-g" onclick="openGroups()">${g.icon} ${g.name}</span>`).join('')}</div>`;}
  if(bs.length){h+=`<div class="xl-k" style="margin-top:11px">BLOCS \u0026 ALIGNMENTS</div><div class="xl-chips">${bs.map(b=>`<span class="xl-chip xl-b" onclick="openBlocs()">\u2b21 ${b.name}</span>`).join('')}</div>`;}
  if(ss.length){h+=`<div class="xl-k" style="margin-top:11px">SYSTEMS</div><div class="xl-chips">${ss.map(s=>`<span class="xl-chip xl-s" onclick="openSystems()">\u25c8 ${s.name}</span>`).join('')}</div>`;}
  h+='</div>';
  return h;
}
