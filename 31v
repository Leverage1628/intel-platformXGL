}

const BUILD_DAY=new Date("2026-07-17");
function freshCls(a){if(!a)return "fr-old";const mns={Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};const p=a.split(" ");const dt=new Date(+p[2],mns[p[1]],+p[0]);const dd=(BUILD_DAY-dt)/86400000;return dd<=1?"fr-ok":dd<=3?"fr-age":"fr-old";}
function histPanel(d){
  const h=d.history; if(!h)return '';
  const roots=h.roots?`<div class="section"><div class="section-head" style="color:var(--ice)">\u25f7 ROOTS \u00b7 HOW IT GOT HERE</div><div class="hist-roots">${h.roots}</div></div>`:'';
  const tl=(h.timeline&&h.timeline.length)?`<div class="section"><div class="section-head" style="color:var(--amber)">\u25f7 TIMELINE</div><div class="htl">${h.timeline.map(t=>`<div class="htl-row"><div class="htl-date">${t.date}</div><div class="htl-line"><span class="htl-dot"></span></div><div class="htl-e">${t.e}</div></div>`).join('')}</div></div>`:'';
  const act=(h.actors&&h.actors.length)?`<div class="section"><div class="section-head" style="color:var(--ext)">\u25f7 ACTORS \u00b7 WHO THEY ARE</div><div class="hact">${h.actors.map(a=>`<div class="hact-card"><div class="hact-name">${a.name}</div><div class="hact-bio">${a.bio}</div></div>`).join('')}</div></div>`:'';
  const br=h.bridge?`<div class="section"><div class="section-head" style="color:var(--red)">\u25f7 THEN \u2192 NOW \u00b7 WHY THIS HISTORY IS THE CRISIS</div><div class="hist-bridge">${h.bridge}</div></div>`:'';
  const src=(h.sources&&h.sources.length)?`<div class="section"><div class="section-head" style="color:var(--grn)">\u25f7 SOURCES \u00b7 SCHOLARSHIP &amp; PRIMARY TEXTS</div><div class="hsrc">${h.sources.map(x=>`<div class="hsrc-row"><span class="hsrc-work">${x.work}</span><span class="hsrc-auth">${x.author}${x.year?' \u00b7 '+x.year:''}</span>${x.note?`<div class="hsrc-note">${x.note}</div>`:''}</div>`).join('')}</div></div>`:'';
  return roots+tl+br+act+src;
}
